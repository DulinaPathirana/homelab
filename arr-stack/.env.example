# ── VPN ──────────────────────────────────────────────────────────────────────
VPN_SERVICE_PROVIDER=[PROVIDER]
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=your_wireguard_private_key_here
SERVER_COUNTRIES=Sweden
SERVER_GROUPS=P2P

# ── Network ───────────────────────────────────────────────────────────────────
# Your LAN subnet — lets arr apps reach local services through the VPN container
LOCAL_SUBNET=192.168.1.0/24
# Physical NIC name on the host (check with: ip link)
HOST_INTERFACE=enp1s0

# ── User / Timezone ───────────────────────────────────────────────────────────
TZ=Australia/Brisbane
PUID=1000
PGID=1000

# ── Paths ─────────────────────────────────────────────────────────────────────
CONFIG_BASE=/home/user/arr-stack
DOWNLOADS_PATH=/mnt/media/downloads
TV_PATH=/mnt/media/tv
MOVIES_PATH=/mnt/media/movies
