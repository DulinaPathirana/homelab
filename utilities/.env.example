TZ=Australia/Brisbane
PUID=1000
PGID=1000

# Portainer
PORTAINER_HTTP_PORT=9000
PORTAINER_HTTPS_PORT=9443

# Glance
GLANCE_PORT=3005
GLANCE_CONFIG_PATH=/opt/glance/glance.yml

# Organizr
ORGANIZR_PORT=8888
ORGANIZR_CONFIG_PATH=/opt/organizr/config

# Monitorr
MONITORR_PORT=8083
MONITORR_CONFIG_PATH=/opt/monitorr/config

# Twingate (get tokens from Twingate Admin Console → Connectors)
TWINGATE_NETWORK=your_network.twingate.com
TWINGATE_ACCESS_TOKEN=your_access_token_here
TWINGATE_REFRESH_TOKEN=your_refresh_token_here
TWINGATE_LABEL_HOSTNAME=homelab

# Anisette
ANISETTE_PORT=6969
